{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ion Music Box",
  "version": "0.1.0",
  "identifier": "com.ion66.ion-music-box",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Ion Music Box",
        "width": 1000,
        "height": 680,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "visible": false,
        "backgroundColor": [24, 24, 28, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src https: http: tauri:; font-src 'self'; img-src 'self' data: blob: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
